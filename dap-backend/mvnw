set -e

MAVEN_PROJECTBASEDIR="${MAVEN_BASEDIR:-""}"

if [ -z "${MAVEN_PROJECTBASEDIR}" ]; then
  MAVEN_PROJECTBASEDIR="$(cd "$(dirname "$0")" && pwd)"
fi

WRAPPER_PROPERTIES="${MAVEN_PROJECTBASEDIR}/.mvn/wrapper/maven-wrapper.properties"
WRAPPER_JAR="${MAVEN_PROJECTBASEDIR}/.mvn/wrapper/maven-wrapper.jar"

if [ -r "${WRAPPER_PROPERTIES}" ]; then
  DOWNLOAD_URL=$(grep 'wrapperUrl' "${WRAPPER_PROPERTIES}" | cut -d'=' -f2)
  DISTRIBUTION_URL=$(grep 'distributionUrl' "${WRAPPER_PROPERTIES}" | cut -d'=' -f2)
fi

if [ ! -e "${WRAPPER_JAR}" ] && [ -n "${DOWNLOAD_URL}" ]; then
  if command -v curl > /dev/null 2>&1; then
    curl -fsSLo "${WRAPPER_JAR}" "${DOWNLOAD_URL}"
  elif command -v wget > /dev/null 2>&1; then
    wget -q -O "${WRAPPER_JAR}" "${DOWNLOAD_URL}"
  else
    echo "ERROR: curl or wget required to download the Maven wrapper jar." >&2
    exit 1
  fi
fi

if [ -n "${JAVA_HOME}" ]; then
  JAVACMD="${JAVA_HOME}/bin/java"
else
  JAVACMD="$(command -v java)"
fi

if [ -z "${JAVACMD}" ] || [ ! -x "${JAVACMD}" ]; then
  echo "ERROR: JAVA_HOME is not set and no 'java' command found in PATH." >&2
  exit 1
fi

exec "${JAVACMD}" \
  ${MAVEN_OPTS} \
  -classpath "${WRAPPER_JAR}" \
  "-Dmaven.multiModuleProjectDirectory=${MAVEN_PROJECTBASEDIR}" \
  org.apache.maven.wrapper.MavenWrapperMain \
  "$@"
