<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Creates the group_question table for TABLE_PER_CLASS inheritance.
        GroupQuestion extends TextQuestion, so this table contains all inherited
        columns (category, question, keywords) plus the ordered flag.
        The keywords column is always null for group rows.
        Note: the legacy question_group table from the baseline remains untouched.
    -->
    <changeSet id="2026-05-29-004-group-question-table" author="gregory.robson">

        <createTable tableName="group_question">
            <column name="id" type="UUID" defaultValueComputed="gen_random_uuid()">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="category" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="question" type="TEXT">
                <constraints nullable="false"/>
            </column>
            <column name="keywords" type="JSONB"/>
            <column name="ordered" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMPTZ"/>
            <column name="updated_at" type="TIMESTAMPTZ"/>
        </createTable>

        <rollback>
            <dropTable tableName="group_question"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
