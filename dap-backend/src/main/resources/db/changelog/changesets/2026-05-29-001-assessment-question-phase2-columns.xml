<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        The Phase 0 baseline created assessment_question with body/dtype/question_bank_id.
        Phase 2 redesigns the entity to use category/question/type (TABLE_PER_CLASS, no question bank FK).
        This changeset adds the required columns so Hibernate validation passes.
    -->
    <changeSet id="2026-05-29-001-assessment-question-phase2-columns" author="norifumi.moodley">

        <addColumn tableName="assessment_question">
            <column name="category" type="VARCHAR(255)" defaultValue="UNCATEGORIZED">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="assessment_question">
            <column name="question" type="TEXT" defaultValue="">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="assessment_question">
            <column name="type" type="VARCHAR(50)" defaultValue="MCQ">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <sql>
            ALTER TABLE assessment_question
                ALTER COLUMN category DROP DEFAULT,
                ALTER COLUMN question DROP DEFAULT,
                ALTER COLUMN type DROP DEFAULT;
        </sql>

        <rollback>
            <dropColumn tableName="assessment_question" columnName="category"/>
            <dropColumn tableName="assessment_question" columnName="question"/>
            <dropColumn tableName="assessment_question" columnName="type"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
