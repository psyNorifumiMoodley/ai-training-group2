<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <changeSet id="2026-06-10-008-add-marks-to-doc-question" author="norifumi.moodley">

        <addColumn tableName="doc_question">
            <column name="marks" type="INTEGER" defaultValueNumeric="1">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <sql>ALTER TABLE doc_question ALTER COLUMN marks DROP DEFAULT;</sql>

        <rollback>
            <dropColumn tableName="doc_question" columnName="marks"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
