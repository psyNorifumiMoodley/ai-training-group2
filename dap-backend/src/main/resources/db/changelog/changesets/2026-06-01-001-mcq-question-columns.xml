<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.20.xsd">

    <!--
        Restructures mcq_question for TABLE_PER_CLASS inheritance.
        The baseline created mcq_question with only an id FK to assessment_question.
        TABLE_PER_CLASS requires each concrete table to contain all inherited columns.
        Drop the FK and add the missing columns so Hibernate validation passes.
    -->
    <changeSet id="2026-06-01-001-mcq-question-columns" author="pierre.duplessis">

        <dropForeignKeyConstraint baseTableName="mcq_question"
                                  constraintName="fk_mcq_question_assessment_question"/>

        <addColumn tableName="mcq_question">
            <column name="category" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="mcq_question">
            <column name="question" type="TEXT">
                <constraints nullable="false"/>
            </column>
        </addColumn>

        <addColumn tableName="mcq_question">
            <column name="created_at" type="TIMESTAMPTZ"/>
        </addColumn>

        <addColumn tableName="mcq_question">
            <column name="updated_at" type="TIMESTAMPTZ"/>
        </addColumn>

        <rollback>
            <dropColumn tableName="mcq_question" columnName="updated_at"/>
            <dropColumn tableName="mcq_question" columnName="created_at"/>
            <dropColumn tableName="mcq_question" columnName="question"/>
            <dropColumn tableName="mcq_question" columnName="category"/>
            <addForeignKeyConstraint baseTableName="mcq_question"
                                     baseColumnNames="id"
                                     constraintName="fk_mcq_question_assessment_question"
                                     referencedTableName="assessment_question"
                                     referencedColumnNames="id"/>
        </rollback>

    </changeSet>

</databaseChangeLog>
